# ─── DATABASE ────────────────────────────────────────────────────────
# Docker local (via docker-compose):
#   DATABASE_URL="postgresql://calendar:calendar@localhost:5432/calendar?schema=public"
#
# Vercel production:
#   Use Vercel Postgres connection string from dashboard
#   DATABASE_URL="postgresql://user:password@host:5432/neondb?sslmode=require&pgbouncer=true&schema=public"
#
DATABASE_URL="postgresql://calendar:calendar@localhost:5432/calendar?schema=public"

# Direct DB URL — used for Prisma migrations (bypasses connection poolers)
# Docker local: same as DATABASE_URL
# Vercel:       Use the "direct" connection string from Vercel Postgres (no pgbouncer flag)
DIRECT_DATABASE_URL="postgresql://calendar:calendar@localhost:5432/calendar?schema=public"

# ─── N8N ──────────────────────────────────────────────────────────────
# Docker local: N8N runs on the docker-compose network at http://n8n:5678
# Production:   URL of your self-hosted or cloud N8N instance
N8N_WEBHOOK_BASE_URL="http://n8n:5678"

# API key for outbound calls from app → N8N
N8N_API_KEY=""

# Shared secret for HMAC signing of webhook payloads (both directions)
# Generate: openssl rand -hex 32
N8N_WEBHOOK_SECRET=""

# ─── AUTH ─────────────────────────────────────────────────────────────
# Generate via: openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth — set up at https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── APP ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── SENTRY (optional) ───────────────────────────────────────────────
# https://docs.sentry.io/platforms/javascript/guides/nextjs/
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# Enable Sentry authentication during builds (set in Vercel dashboard)
# SENTRY_AUTH_TOKEN=""
